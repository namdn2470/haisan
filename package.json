{
  "name": "hai-san-bien-xanh",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@hsbx/web",
    "dev:web": "turbo dev --filter=@hsbx/web",
    "dev:api": "turbo dev --filter=@hsbx/api",
    "dev:full": "turbo dev --filter=@hsbx/web --filter=@hsbx/api",
    "dev:mobile": "turbo dev --filter=@hsbx/mobile",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "db:migrate": "pnpm --filter @hsbx/db run db:migrate",
    "db:seed": "pnpm --filter @hsbx/db run db:seed",
    "db:studio": "pnpm --filter @hsbx/db run db:studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
