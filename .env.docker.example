# ================================================================
# BIẾN MÔI TRƯỜNG DOCKER — Copy file này thành .env
# Sử dụng với: docker-compose.prod.yml
# ================================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=hai_san_bien_xanh

# --- API (NestJS) ---
# DATABASE_URL phải trỏ đến service postgres trong Docker network
DATABASE_URL=postgresql://postgres:your_strong_password_here@postgres:5432/hai_san_bien_xanh
DIRECT_URL=postgresql://postgres:your_strong_password_here@postgres:5432/hai_san_bien_xanh
API_PORT=3001
JWT_SECRET=your_very_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# --- Web (Next.js) ---
# NEXT_PUBLIC_API_URL: URL trình duyệt gọi đến API (domain thật khi production)
# Được baked vào bundle tại build time — set khi build image
NEXT_PUBLIC_API_URL=https://your-domain.com

# --- Docker Compose (prod) ---
# Tên image đã build (dùng với docker-compose.prod.yml)
API_IMAGE=hsbx-api
WEB_IMAGE=hsbx-web
IMAGE_TAG=latest

# Cổng expose của web container ra bên ngoài host
WEB_PORT=3000
