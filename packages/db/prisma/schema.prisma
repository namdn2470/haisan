generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CUSTOMER
  MANAGER
  ADMIN
  STAFF
  SHIPPER
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum ProductUnit {
  KG
  CON
  COMBO
  HOP
}

enum ProductBadge {
  BAN_CHAY
  UU_DAI
  TUOI_NGON
  MOI
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
  ZALO_PAY
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  DELIVERING
  COMPLETED
  CANCELLED
  RETURNED
}

enum OrderSource {
  WEBSITE
  MOBILE_APP
  ZALO_MINI_APP
  FACEBOOK
  TIKTOK
  ADMIN
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERING
  DELIVERED
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum BannerPosition {
  HOME_HERO
  HOME_PROMO
  MOBILE_HERO
  SIDEBAR_PROMO
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum NotificationType {
  ORDER_NEW
  ORDER_PAID
  ORDER_DELIVERED
  PRODUCT_LOW_STOCK
  PROMOTION
  SYSTEM
}

model Profile {
  id           String     @id @default(uuid()) @db.Uuid
  fullName     String?    @map("full_name")
  phone        String?    @unique
  email        String?    @unique
  passwordHash String?    @map("password_hash")
  avatarUrl    String?    @map("avatar_url")
  role         UserRole   @default(CUSTOMER)
  status       UserStatus @default(ACTIVE)
  customRoleId String?    @map("custom_role_id") @db.Uuid

  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  reviews       Review[]
  favorites     Favorite[]
  deliveries    Delivery[]     @relation("ShipperDeliveries")
  notifications Notification[]
  auditLogs      AuditLog[]     @relation("ActorAuditLogs")
  posts          Post[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Address {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @map("user_id") @db.Uuid
  receiverName  String  @map("receiver_name")
  receiverPhone String  @map("receiver_phone")
  province      String
  district      String
  ward          String
  addressLine   String  @map("address_line")
  note          String?
  isDefault     Boolean @default(false) @map("is_default")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("addresses")
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  parentId    String? @map("parent_id") @db.Uuid
  name        String
  slug        String  @unique
  description String?
  imageUrl    String? @map("image_url")
  iconUrl     String? @map("icon_url")
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Product {
  id                 String        @id @default(uuid()) @db.Uuid
  categoryId         String        @map("category_id") @db.Uuid
  name               String
  slug               String        @unique
  shortDescription   String?       @map("short_description")
  description        String?
  origin             String?
  storageInstruction String?       @map("storage_instruction")
  unit               ProductUnit   @default(KG)
  basePrice          Decimal       @map("base_price") @db.Decimal(12, 2)
  oldPrice           Decimal?      @map("old_price") @db.Decimal(12, 2)
  status             ProductStatus @default(ACTIVE)
  badge              ProductBadge?
  isFeatured         Boolean       @default(false) @map("is_featured")
  isBestSeller       Boolean       @default(false) @map("is_best_seller")
  isFreshLive        Boolean       @default(true) @map("is_fresh_live")
  ratingAvg          Decimal       @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount        Int           @default(0) @map("rating_count")
  soldCount          Int           @default(0) @map("sold_count")

  category          Category                  @relation(fields: [categoryId], references: [id])
  images            ProductImage[]
  variants          ProductVariant[]
  inventory         Inventory[]
  inventoryLogs     InventoryLog[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  reviews           Review[]
  favorites         Favorite[]
  processingOptions ProductProcessingOption[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([isBestSeller])
  @@map("products")
}

model ProductImage {
  id          String  @id @default(uuid()) @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  imageUrl    String  @map("image_url")
  altText     String? @map("alt_text")
  sortOrder   Int     @default(0) @map("sort_order")
  isThumbnail Boolean @default(false) @map("is_thumbnail")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id            String      @id @default(uuid()) @db.Uuid
  productId     String      @map("product_id") @db.Uuid
  name          String
  sizeLabel     String?     @map("size_label")
  minWeight     Decimal?    @map("min_weight") @db.Decimal(8, 2)
  maxWeight     Decimal?    @map("max_weight") @db.Decimal(8, 2)
  unit          ProductUnit @default(KG)
  price         Decimal     @db.Decimal(12, 2)
  oldPrice      Decimal?    @map("old_price") @db.Decimal(12, 2)
  stockQuantity Decimal     @default(0) @map("stock_quantity") @db.Decimal(12, 2)
  sku           String      @unique
  isActive      Boolean     @default(true) @map("is_active")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory  Inventory[]
  inventoryLogs InventoryLog[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProcessingService {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Decimal @default(0) @db.Decimal(12, 2)
  isActive    Boolean @default(true) @map("is_active")

  productOptions ProductProcessingOption[]
  cartItems       CartItem[]
  orderItems      OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("processing_services")
}

model ProductProcessingOption {
  id                  String @id @default(uuid()) @db.Uuid
  productId            String @map("product_id") @db.Uuid
  processingServiceId  String @map("processing_service_id") @db.Uuid

  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  processingService ProcessingService @relation(fields: [processingServiceId], references: [id], onDelete: Cascade)

  @@unique([productId, processingServiceId])
  @@map("product_processing_options")
}

model Inventory {
  id                String  @id @default(uuid()) @db.Uuid
  productId          String  @map("product_id") @db.Uuid
  variantId          String? @map("variant_id") @db.Uuid
  quantity           Decimal @default(0) @db.Decimal(12, 2)
  reservedQuantity   Decimal @default(0) @map("reserved_quantity") @db.Decimal(12, 2)
  lowStockThreshold  Decimal @default(5) @map("low_stock_threshold") @db.Decimal(12, 2)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([variantId])
  @@map("inventory")
}

model Cart {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String?    @map("user_id") @db.Uuid
  sessionId String?    @map("session_id")
  status    CartStatus @default(ACTIVE)

  user  Profile?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id                  String      @id @default(uuid()) @db.Uuid
  cartId              String      @map("cart_id") @db.Uuid
  productId           String      @map("product_id") @db.Uuid
  variantId           String?     @map("variant_id") @db.Uuid
  quantity            Decimal     @db.Decimal(12, 2)
  selectedUnit        ProductUnit @map("selected_unit")
  processingServiceId String?     @map("processing_service_id") @db.Uuid
  priceAtTime         Decimal     @map("price_at_time") @db.Decimal(12, 2)
  note                String?

  cart              Cart               @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id])
  variant           ProductVariant?    @relation(fields: [variantId], references: [id])
  processingService ProcessingService? @relation(fields: [processingServiceId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model DeliveryTimeSlot {
  id        String  @id @default(uuid()) @db.Uuid
  label     String
  startTime String  @map("start_time")
  endTime   String  @map("end_time")
  maxOrders Int     @default(20) @map("max_orders")
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  orders Order[]

  @@map("delivery_time_slots")
}

model Order {
  id                  String        @id @default(uuid()) @db.Uuid
  orderCode           String        @unique @map("order_code")
  userId              String?       @map("user_id") @db.Uuid
  customerName        String        @map("customer_name")
  customerPhone       String        @map("customer_phone")
  customerEmail       String?       @map("customer_email")
  shippingAddressId   String?       @map("shipping_address_id") @db.Uuid
  shippingAddressText String        @map("shipping_address_text")
  deliveryDate        DateTime      @map("delivery_date") @db.Date
  deliveryTimeSlotId  String?       @map("delivery_time_slot_id") @db.Uuid
  paymentMethod       PaymentMethod @map("payment_method")
  paymentStatus       PaymentStatus @default(UNPAID) @map("payment_status")
  orderStatus         OrderStatus   @default(NEW) @map("order_status")
  subtotal            Decimal       @default(0) @db.Decimal(12, 2)
  processingFee       Decimal       @default(0) @map("processing_fee") @db.Decimal(12, 2)
  shippingFee         Decimal       @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  discountAmount      Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount         Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  customerNote        String?       @map("customer_note")
  adminNote           String?       @map("admin_note")
  source              OrderSource   @default(WEBSITE)

  user             Profile?          @relation(fields: [userId], references: [id])
  shippingAddress  Address?          @relation(fields: [shippingAddressId], references: [id])
  deliveryTimeSlot DeliveryTimeSlot?  @relation(fields: [deliveryTimeSlotId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  deliveries       Delivery[]
  coupons          OrderCoupon[]
  reviews          Review[]
  statusHistory    OrderStatusHistory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([orderCode])
  @@index([orderStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id                    String      @id @default(uuid()) @db.Uuid
  orderId               String      @map("order_id") @db.Uuid
  productId             String      @map("product_id") @db.Uuid
  variantId             String?     @map("variant_id") @db.Uuid
  productName           String      @map("product_name")
  variantName           String?     @map("variant_name")
  unit                  ProductUnit
  quantity              Decimal     @db.Decimal(12, 2)
  price                 Decimal     @db.Decimal(12, 2)
  processingServiceId   String?     @map("processing_service_id") @db.Uuid
  processingServiceName String?     @map("processing_service_name")
  processingFee         Decimal     @default(0) @map("processing_fee") @db.Decimal(12, 2)
  totalPrice            Decimal     @map("total_price") @db.Decimal(12, 2)

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id])
  variant           ProductVariant?    @relation(fields: [variantId], references: [id])
  processingService ProcessingService? @relation(fields: [processingServiceId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  orderId          String        @map("order_id") @db.Uuid
  method           PaymentMethod
  amount           Decimal       @db.Decimal(12, 2)
  status           PaymentStatus @default(UNPAID)
  transactionCode  String?       @map("transaction_code")
  paidAt           DateTime?     @map("paid_at")
  rawData          Json?         @map("raw_data")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("payments")
}

model Delivery {
  id                  String         @id @default(uuid()) @db.Uuid
  orderId             String         @map("order_id") @db.Uuid
  shipperId           String?        @map("shipper_id") @db.Uuid
  status              DeliveryStatus @default(PENDING)
  deliveryFee         Decimal        @default(0) @map("delivery_fee") @db.Decimal(12, 2)
  estimatedDeliveryAt DateTime?      @map("estimated_delivery_at")
  deliveredAt         DateTime?      @map("delivered_at")
  note                String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shipper Profile? @relation("ShipperDeliveries", fields: [shipperId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([shipperId])
  @@map("deliveries")
}

model Promotion {
  id                String       @id @default(uuid()) @db.Uuid
  code              String       @unique
  name              String
  description       String?
  discountType      DiscountType @map("discount_type")
  discountValue     Decimal      @map("discount_value") @db.Decimal(12, 2)
  minOrderAmount    Decimal      @default(0) @map("min_order_amount") @db.Decimal(12, 2)
  maxDiscountAmount Decimal?     @map("max_discount_amount") @db.Decimal(12, 2)
  startAt           DateTime     @map("start_at")
  endAt             DateTime     @map("end_at")
  usageLimit        Int?         @map("usage_limit")
  usedCount         Int          @default(0) @map("used_count")
  isActive          Boolean      @default(true) @map("is_active")

  orderCoupons OrderCoupon[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("promotions")
}

model OrderCoupon {
  id             String  @id @default(uuid()) @db.Uuid
  orderId         String  @map("order_id") @db.Uuid
  promotionId     String  @map("promotion_id") @db.Uuid
  discountAmount  Decimal @map("discount_amount") @db.Decimal(12, 2)

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("order_coupons")
}

model Review {
  id        String       @id @default(uuid()) @db.Uuid
  productId String       @map("product_id") @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  orderId   String?      @map("order_id") @db.Uuid
  rating    Int
  comment   String?
  images    Json?
  status    ReviewStatus @default(PENDING)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  order   Order?  @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

model Favorite {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  productId String @map("product_id") @db.Uuid

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@map("favorites")
}

model Banner {
  id        String         @id @default(uuid()) @db.Uuid
  title     String
  subtitle  String?
  imageUrl  String         @map("image_url")
  linkUrl   String?        @map("link_url")
  position  BannerPosition
  sortOrder Int            @default(0) @map("sort_order")
  isActive  Boolean        @default(true) @map("is_active")
  startAt   DateTime?      @map("start_at")
  endAt     DateTime?      @map("end_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([position])
  @@index([isActive])
  @@map("banners")
}

model Notification {
  id      String           @id @default(uuid()) @db.Uuid
  userId  String?          @map("user_id") @db.Uuid
  title   String
  message String
  type    NotificationType
  isRead  Boolean          @default(false) @map("is_read")
  data    Json?

  user Profile? @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model AuditLog {
  id         String @id @default(uuid()) @db.Uuid
  actorId    String? @map("actor_id") @db.Uuid
  action     String
  entityType String  @map("entity_type")
  entityId   String? @map("entity_id") @db.Uuid
  oldData    Json?   @map("old_data")
  newData    Json?   @map("new_data")

  actor Profile? @relation("ActorAuditLogs", fields: [actorId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType])
  @@map("audit_logs")
}

model Post {
  id             String     @id @default(uuid()) @db.Uuid
  title          String
  slug           String     @unique
  thumbnailUrl   String?    @map("thumbnail_url")
  excerpt        String?
  content        String?
  authorId       String?    @map("author_id") @db.Uuid
  status         PostStatus @default(DRAFT)
  seoTitle       String?    @map("seo_title")
  seoDescription String?     @map("seo_description")
  viewCount      Int        @default(0) @map("view_count")
  publishedAt    DateTime?  @map("published_at")

  author Profile? @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@map("posts")
}

model OrderStatusHistory {
  id        String @id @default(uuid()) @db.Uuid
  orderId   String @map("order_id") @db.Uuid
  status    String
  note      String?
  actorId   String? @map("actor_id") @db.Uuid
  actorName String? @map("actor_name")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_status_history")
}

enum InventoryLogType {
  IMPORT
  EXPORT
  ADJUSTMENT
}

model ShippingZone {
  id              String  @id @default(uuid()) @db.Uuid
  name            String
  province        String?
  district        String?
  shippingFee     Decimal @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  freeFromAmount  Decimal @default(0) @map("free_from_amount") @db.Decimal(12, 2)
  estimatedDays   Int     @default(1) @map("estimated_days")
  isActive        Boolean @default(true) @map("is_active")
  sortOrder       Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder])
  @@map("shipping_zones")
}

model InventoryLog {
  id            String           @id @default(uuid()) @db.Uuid
  productId     String           @map("product_id") @db.Uuid
  variantId     String?          @map("variant_id") @db.Uuid
  type          InventoryLogType
  quantity      Decimal          @db.Decimal(12, 2)
  oldQuantity   Decimal          @default(0) @map("old_quantity") @db.Decimal(12, 2)
  newQuantity   Decimal          @default(0) @map("new_quantity") @db.Decimal(12, 2)
  note          String?
  createdBy     String?          @map("created_by") @db.Uuid

  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([variantId])
  @@index([type])
  @@index([createdBy])
  @@index([createdAt])
  @@map("inventory_logs")
}

model CustomRole {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  color       String   @default("#64748b")
  permissions String[] @default([])
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false) @map("is_system")

  profiles    Profile[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([slug])
  @@map("custom_roles")
}

// Site Configuration - Key-value store for website settings
model SiteConfig {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // string, number, boolean, json
  group       String   @default("general") // general, topbar, homepage, menu
  label       String?
  description String?
  isPublic   Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@index([group])
  @@index([isPublic])
  @@map("site_configs")
}

// Store Settings - Single-row store configuration
model StoreSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  storeName             String   @default("Hải Sản Biển Xanh") @map("store_name")
  storeDescription       String?  @map("store_description") @db.Text
